          "name": "Get All Service Configs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/config/services",
              "host": ["{{base_url}}"],
              "path": ["api", "config", "services"]
            },
            "description": "Full ServiceConfig list: name, httpPort, grpcPort, packageName, className, hasOutbox, hasSaga, ownedSchemas, envVars."
          }
        },
        {
          "name": "Get Service Config by Name",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/config/services/{{service_name}}",
              "host": ["{{base_url}}"],
              "path": ["api", "config", "services", "{{service_name}}"]
