{
  "info": {
    "name": "FractalX Admin Service",
    "description": "Complete REST API collection for the FractalX Admin Service (generated at port 9090).\n\nPre-seeded users:\n  admin   / admin123  → ROLE_ADMIN\n  viewer  / viewer123 → ROLE_VIEWER\n\nSet the {{base_url}} variable to http://localhost:9090 before running.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "fractalx-admin-v1"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:9090",
      "type": "string"
    },
    {
      "key": "service_name",
      "value": "order-service",
      "type": "string"
    },
    {
      "key": "username",
      "value": "admin",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🔐 Authentication",
      "description": "Form-based Spring Security login. On success a session cookie is set and used by all subsequent requests.",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "admin",    "type": "text" },
                { "key": "password", "value": "admin123", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/login",
              "host": ["{{base_url}}"],
              "path": ["login"]
            },
            "description": "Authenticates with Spring Security. The session cookie returned is automatically sent by Postman on all subsequent requests."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/logout",
              "host": ["{{base_url}}"],
              "path": ["logout"]
            }
          }
        },
        {
          "name": "Get Current User Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/auth/profile",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "profile"]
            },
            "description": "Returns username and roles of the currently authenticated user from SecurityContextHolder."
          }
        }
      ]
    },
    {
      "name": "🖥️ Services",
      "description": "Endpoints for the Services section of the dashboard — health, deployment stages, metrics, and docker-compose lifecycle commands.",
      "item": [
        {
          "name": "Get All Services",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/services/all",
              "host": ["{{base_url}}"],
              "path": ["api", "services", "all"]
            },
            "description": "Returns all services (decomposed microservices + infrastructure: registry, gateway, admin, logger) with live health status, baked metadata, latest deployment, and lifecycle commands."
          }
        },
        {
          "name": "Get Service Detail",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/services/{{service_name}}/detail",
              "host": ["{{base_url}}"],
              "path": ["api", "services", "{{service_name}}", "detail"]
            },
            "description": "Full detail for a single service: metadata, live health, latest deployment stages."
          }
        },
        {
          "name": "Get Service Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/services/{{service_name}}/health",
              "host": ["{{base_url}}"],
              "path": ["api", "services", "{{service_name}}", "health"]
            },
            "description": "Proxies to the service's Spring Actuator /actuator/health endpoint."
          }
        },
        {
          "name": "Get Service Metrics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/services/{{service_name}}/metrics",
              "host": ["{{base_url}}"],
              "path": ["api", "services", "{{service_name}}", "metrics"]
            },
            "description": "Proxies to the service's Spring Actuator /actuator/metrics endpoint."
          }
        },
        {
          "name": "Get Latest Deployment",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/services/{{service_name}}/deployment",
              "host": ["{{base_url}}"],
              "path": ["api", "services", "{{service_name}}", "deployment"]
            },
            "description": "Returns the most recent DeploymentRecord for this service including BUILD / PACKAGE / DEPLOY stage statuses."
          }
        },
        {
          "name": "Get Deployment History",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/services/{{service_name}}/history",
              "host": ["{{base_url}}"],
              "path": ["api", "services", "{{service_name}}", "history"]
            },
            "description": "Full deployment history list for the service."
          }
        },
        {
          "name": "Get Lifecycle Commands",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/services/{{service_name}}/commands",
              "host": ["{{base_url}}"],
              "path": ["api", "services", "{{service_name}}", "commands"]
            },
            "description": "Returns docker-compose commands for start, stop, restart, logs, build, and pull for this service. Commands are display-only — no Docker socket interaction."
          }
        }
      ]
    },
    {
      "name": "🔗 Communication",
      "description": "Service dependency graph, NetScope/gRPC links, API gateway, and service discovery.",
      "item": [
        {
          "name": "Get Topology Graph",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/communication/topology",
              "host": ["{{base_url}}"],
              "path": ["api", "communication", "topology"]
            },
            "description": "Returns the full service dependency graph as { nodes: [...], edges: [...] }. Edges represent NetScope/gRPC connections with gRPC port numbers."
          }
        },
        {
          "name": "Get All NetScope Links",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/communication/netscope",
              "host": ["{{base_url}}"],
              "path": ["api", "communication", "netscope"]
            },
            "description": "Returns all baked NetScope/gRPC dependency links derived from FractalModule dependencies at generation time. Includes source service, target service, gRPC port, and protocol."
          }
        },
        {
          "name": "Get NetScope Links for Service",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/communication/netscope/{{service_name}}",
              "host": ["{{base_url}}"],
              "path": ["api", "communication", "netscope", "{{service_name}}"]
            },
            "description": "NetScope links for a single source service."
          }
        },
        {
          "name": "Get Gateway Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/communication/gateway/health",
              "host": ["{{base_url}}"],
              "path": ["api", "communication", "gateway", "health"]
            },
            "description": "Proxies to the API Gateway (port 8080) /actuator/health."
          }
        },
        {
          "name": "Get Gateway Metrics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/communication/gateway/metrics",
              "host": ["{{base_url}}"],
              "path": ["api", "communication", "gateway", "metrics"]
            },
            "description": "Proxies to the API Gateway (port 8080) /actuator/metrics."
          }
        },
        {
          "name": "Get Discovery Stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/communication/discovery/stats",
              "host": ["{{base_url}}"],
              "path": ["api", "communication", "discovery", "stats"]
            },
            "description": "Proxies to fractalx-registry (port 8761) /services and returns { status, count, registryUrl, services }."
          }
        }
      ]
    },
    {
      "name": "🗄️ Data Consistency",
      "description": "Saga orchestration definitions, database health per service, schema ownership, and outbox metrics.",
      "item": [
        {
          "name": "Get Data Consistency Overview",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/data/overview",
              "host": ["{{base_url}}"],
              "path": ["api", "data", "overview"]
            },
            "description": "Returns { totalServices, totalSagas, sagaOrchestrator: { health, url } }."
          }
        },
        {
          "name": "Get Saga Definitions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/data/sagas",
              "host": ["{{base_url}}"],
              "path": ["api", "data", "sagas"]
            },
            "description": "All baked saga definitions from SagaMetaRegistry — sagaId, orchestratedBy, steps, compensationSteps, enabled."
          }
        },
        {
          "name": "Get All Saga Instances",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/data/sagas/instances",
              "host": ["{{base_url}}"],
              "path": ["api", "data", "sagas", "instances"]
            },
            "description": "Proxies to fractalx-saga-orchestrator (port 8099) GET /saga — returns all running/completed SagaInstance records."
          }
        },
        {
          "name": "Get Saga Instances by Saga ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/data/sagas/orderServiceSaga/instances",
              "host": ["{{base_url}}"],
              "path": ["api", "data", "sagas", "orderServiceSaga", "instances"]
            },
            "description": "Proxies to the saga orchestrator filtered by sagaId."
          }
        },
        {
          "name": "Get Database Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/data/databases",
              "host": ["{{base_url}}"],
              "path": ["api", "data", "databases"]
            },
            "description": "Per-service database health. Proxies to each service's actuator/health/db. Returns [ { service, schemas, health } ]."
          }
        },
        {
          "name": "Get Schema Ownership",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/data/schemas",
              "host": ["{{base_url}}"],
              "path": ["api", "data", "schemas"]
            },
            "description": "Returns schema ownership per service as baked at generation time."
          }
        },
        {
          "name": "Get Outbox Metrics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/data/outbox",
              "host": ["{{base_url}}"],
              "path": ["api", "data", "outbox"]
            },
            "description": "Proxies to each service's actuator to retrieve outbox event metrics (pending/processed counts)."
          }
        }
      ]
    },
    {
      "name": "📊 Observability",
      "description": "Service health metrics, alert management (SSE stream), and distributed trace search.",
      "item": [
        {
          "name": "Get All Service Metrics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/observability/metrics",
              "host": ["{{base_url}}"],
              "path": ["api", "observability", "metrics"]
            },
            "description": "Returns per-service metrics map: { health, response_time_p99, error_rate, uptime_percent }."
          }
        },
        {
          "name": "Get Service Metrics by Name",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/observability/metrics/{{service_name}}",
              "host": ["{{base_url}}"],
              "path": ["api", "observability", "metrics", "{{service_name}}"]
            }
          }
        },
        {
          "name": "Get Health Summary",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/health/summary",
              "host": ["{{base_url}}"],
              "path": ["api", "health", "summary"]
            },
            "description": "Summary of UP/DOWN/UNKNOWN counts across all services."
          }
        },
        {
          "name": "Get Active Alerts",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/alerts/active",
              "host": ["{{base_url}}"],
              "path": ["api", "alerts", "active"]
            }
          }
        },
        {
          "name": "Get Alert History",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/alerts",
              "host": ["{{base_url}}"],
              "path": ["api", "alerts"],
              "query": [
                { "key": "size", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Resolve Alert",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/alerts/:alertId/resolve",
              "host": ["{{base_url}}"],
              "path": ["api", "alerts", ":alertId", "resolve"],
              "variable": [
                { "key": "alertId", "value": "alert-id-here" }
              ]
            }
          }
        },
        {
          "name": "Get Alert Config",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/alerts/config",
              "host": ["{{base_url}}"],
              "path": ["api", "alerts", "config"]
            },
            "description": "Returns alerting.yml contents — rules (3 default) and channels (SSE, Webhook, Email, Slack)."
          }
        },
        {
          "name": "Alert SSE Stream (browser/EventSource only)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "text/event-stream" }
            ],
            "url": {
              "raw": "{{base_url}}/api/alerts/stream",
              "host": ["{{base_url}}"],
              "path": ["api", "alerts", "stream"]
            },
            "description": "Server-Sent Events stream. Connect via EventSource in a browser. Postman can show the stream but won't auto-reconnect."
          }
        }
      ]
    },
    {
      "name": "🔍 Traces",
      "description": "Jaeger distributed trace search via admin proxy.",
      "item": [
        {
          "name": "Search Traces",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/traces?service={{service_name}}&limit=20",
              "host": ["{{base_url}}"],
              "path": ["api", "traces"],
              "query": [
                { "key": "correlationId", "value": "", "disabled": true },
                { "key": "service",       "value": "{{service_name}}" },
                { "key": "limit",         "value": "20" }
              ]
            },
            "description": "Proxies to Jaeger HTTP API (port 16686). Filter by correlationId (X-Correlation-Id header value) or service name."
          }
        },
        {
          "name": "Search Traces by Correlation ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/traces?correlationId=abc-123&limit=20",
              "host": ["{{base_url}}"],
              "path": ["api", "traces"],
              "query": [
                { "key": "correlationId", "value": "abc-123" },
                { "key": "limit",         "value": "20" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "📋 Logs",
      "description": "Log viewer backed by the logger-service (port 9099).",
      "item": [
        {
          "name": "Search Logs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/logs?page=0&size=50",
              "host": ["{{base_url}}"],
              "path": ["api", "logs"],
              "query": [
                { "key": "correlationId", "value": "",     "disabled": true },
                { "key": "service",       "value": "",     "disabled": true },
                { "key": "level",         "value": "",     "disabled": true },
                { "key": "page",          "value": "0" },
                { "key": "size",          "value": "50" }
              ]
            },
            "description": "Proxies to logger-service (port 9099). Filter by correlationId, service, or level (INFO/WARN/ERROR/DEBUG). Paginated."
          }
        },
        {
          "name": "Search Logs by Correlation ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/logs?correlationId=abc-123&page=0&size=50",
              "host": ["{{base_url}}"],
              "path": ["api", "logs"],
              "query": [
                { "key": "correlationId", "value": "abc-123" },
                { "key": "page",          "value": "0" },
                { "key": "size",          "value": "50" }
              ]
            }
          }
        },
        {
          "name": "Search Logs by Service + Level",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/logs?service={{service_name}}&level=ERROR&page=0&size=50",
              "host": ["{{base_url}}"],
              "path": ["api", "logs"],
              "query": [
                { "key": "service", "value": "{{service_name}}" },
                { "key": "level",   "value": "ERROR" },
                { "key": "page",    "value": "0" },
                { "key": "size",    "value": "50" }
              ]
            }
          }
        },
        {
          "name": "Get Log Statistics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/logs/stats",
              "host": ["{{base_url}}"],
              "path": ["api", "logs", "stats"]
            },
            "description": "Returns per-service log stats: { total, errors, warns, infos }."
          }
        },
        {
          "name": "Get Services with Logs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/logs/services",
              "host": ["{{base_url}}"],
              "path": ["api", "logs", "services"]
            },
            "description": "Returns list of distinct service names that have sent logs to the logger-service."
          }
        }
      ]
    },
    {
      "name": "👤 User Management",
      "description": "CRUD for admin users and roles. All /api/users/** endpoints require ROLE_ADMIN.",
      "item": [
        {
          "name": "List All Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users",
              "host": ["{{base_url}}"],
              "path": ["api", "users"]
            },
            "description": "Returns all users. The passwordHash field is masked as *** in the response."
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"operator1\",\n  \"password\": \"pass1234\",\n  \"roles\": [\"ROLE_OPERATOR\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users",
              "host": ["{{base_url}}"],
              "path": ["api", "users"]
            },
            "description": "Creates a new user. Password is BCrypt-hashed before storage. Available roles: ROLE_ADMIN, ROLE_OPERATOR, ROLE_VIEWER."
          }
        },
        {
          "name": "Update User (active flag)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"active\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users/{{username}}",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "{{username}}"]
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users/{{username}}",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "{{username}}"]
            },
            "description": "Deletes a user. Blocks deletion of the currently authenticated user's own account."
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newPassword\": \"newSecurePass123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users/{{username}}/password",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "{{username}}", "password"]
            },
            "description": "Changes a user's password. New password is BCrypt-hashed before storage."
          }
        },
        {
          "name": "Update User Roles",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roles\": [\"ROLE_ADMIN\", \"ROLE_OPERATOR\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users/{{username}}/roles",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "{{username}}", "roles"]
            }
          }
        }
      ]
    },
    {
